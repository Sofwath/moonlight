	.carousel-control:focus,
.carousel-control:active, a:focus, a:active {
    outline: none!important;
    box-shadow: none!important;
}

        .modal-dialog {
            width: 700px;
            position: absolute;
            top: 40%;
            left: 50%;
            transform: translate(-50%, -40%) !important;
        }

            .modal-dialog .modal-background {
                width: 678px;
                background-image: url(https://presidency.gov.mv/Images/splash.png);
                height: 258px;
                background-size: contain;
            }


        .close {
            color: white;
            opacity: 0.6;
            /*position: absolute;*/
            width: 100%;
            float: right;
            font-size: 21px;
            font-weight: bold;
            line-height: 1;
            color: #ffffff;
            text-shadow: 0 1px 0 #ffffff;
            filter: alpha(opacity=20);
            text-align: right;
            padding: 10px !important;
        }

        
            .close, .close:hover, .close:focus {
                opacity: 1;
                filter: alpha(opacity=100);
                color: white;
            }
        button.close {
            z-index: 100;
            position: absolute;
        }


        .modal-body {
            padding: 0px;
        }

        .home-slide {
            width: 1140px;
            background-image: url('https://presidency.gov.mv/Images/sap/sap-slide.png');
